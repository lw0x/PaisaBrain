    <!-- Spending Personalities -->
    <string name="personality_title">உங்கள் செலவு ஆளுமை</string>
    <string name="personality_saver">சேமிப்பாளர்</string>
    <string name="personality_saver_desc">நாகம் தங்கத்தைக் காப்பது போல் பணத்தைக் காக்கிறீர்கள். அருமையான ஒழுக்கம்!</string>
    <string name="personality_balanced">சமநிலையாளர்</string>
    <string name="personality_balanced_desc">புத்திசாலித்தனமாக செலவழித்து, தொடர்ந்து சேமிக்கிறீர்கள். நிதி யூனிகார்ன்!</string>
    <string name="personality_impulsive">உணர்ச்சி ராஜா</string>
    <string name="personality_impulsive_desc">பார்க்கிறீர்கள், பிடிக்கிறது, வாங்குகிறீர்கள். உங்கள் பர்சுக்கு commitment issues!</string>
    <string name="personality_foodie">ஃபுட்டி</string>
    <string name="personality_foodie_desc">உங்கள் வயிறுதான் உங்கள் நிதி ஆலோசகர். உணவு டெலிவரி செயலிகள் உங்களுக்கு நன்றி அட்டை அனுப்புகின்றன.</string>
    <string name="personality_shopper">ஷாப்பிங் மன்னர்</string>
    <string name="personality_shopper_desc">ஆன்லைன் ஷாப்பிங் டெலிவரி பையன் உங்கள் பெயரை அறிவார். Sale சீசன் உங்கள் திருவிழா!</string>
    <string name="personality_splurger">வீக்எண்ட் ஸ்ப்ளர்ஜர்</string>
    <string name="personality_splurger_desc">வாரநாட்கள்: துறவி. வாரயிறுதி: பார்ட்டி. உங்கள் பாலன்ஸ் ரோலர்கோஸ்டர் ஓட்டுகிறது.</string>
    <string name="personality_minimalist">மினிமலிஸ்ட்</string>
    <string name="personality_minimalist_desc">நீங்கள் மிகக் குறைவாக செலவழிக்கிறீர்கள், உங்கள் பர்ஸ் தன் வேலையை மறந்துவிட்டது.</string>
    <string name="personality_investor">முதலீட்டாளர்</string>
    <string name="personality_investor_desc">Mutual funds sahi hai — நீங்கள் உண்மையிலேயே நம்புகிறீர்கள். எதிர்கால நீங்கள் நன்றி சொல்கிறார்!</string>

