    <!-- Budget Alerts -->
    <string name="budget_alert_urgent_title">⚠️ பட்ஜெட் மீறியது!</string>
    <string name="budget_alert_urgent_message">%2$s பட்ஜெட்டுக்கு எதிராக %1$s செலவழித்துள்ளீர்கள் — %3$s அதிகம்! இன்னும் %4$d நாட்கள் உள்ளன. நிறுத்தி திட்டமிடுங்கள்.</string>
    <string name="budget_alert_warning_title">📊 பட்ஜெட் எச்சரிக்கை</string>
    <string name="budget_alert_warning_message">%2$s பட்ஜெட்டில் %1$s செலவழித்துள்ளீர்கள். இந்த வேகத்தில் மாத இறுதியில் %3$s ஆகும் — பட்ஜெட்டை விட %4$s அதிகம். முக்கிய காரணம்: %5$s</string>
    <string name="budget_alert_nudge_title">💡 பட்ஜெட் நிலை</string>
    <string name="budget_alert_nudge_message">பட்ஜெட்டின் %1$s%% பயன்படுத்தியுள்ளீர்கள். தினசரி சராசரி %2$s, %3$d நாட்கள் மீதம். சீராக இருந்தால் சரியாகும்!</string>

    <!-- Onboarding -->
    <string name="onboarding_welcome_title">Paisa Brain-க்கு வரவேற்பு! 🧠</string>
    <string name="onboarding_welcome_desc">உங்கள் மொழியில் பேசும், உங்கள் செலவை ரோஸ்ட் செய்யும் நிதி உதவியாளர்.</string>
    <string name="onboarding_money_title">ஒவ்வொரு பைசாவையும் கண்காணி 💰</string>
    <string name="onboarding_money_desc">SMS &amp; அறிவிப்புகளிலிருந்து தானியங்கி கண்டறிதல். நுண்ணறிவுகள், கணிப்புகள், ஆளுமை பகுப்பாய்வு.</string>
    <string name="onboarding_vault_title">உங்கள் டிஜிட்டல் வால்ட் 🔐</string>
    <string name="onboarding_vault_desc">ஆவணங்கள் ஸ்கேன், குரல் குறிப்புகள், முக்கிய தகவல்கள் சேமிப்பு. எல்லாம் உங்கள் போனில், என்கிரிப்ட் செய்யப்பட்டு.</string>
    <string name="onboarding_roast_title">வாராந்திர ரோஸ்ட் 🔥</string>
    <string name="onboarding_roast_desc">ஒவ்வொரு திங்களும் உங்கள் செலவு பழக்கத்தின் வேடிக்கையான ரோஸ்ட். வேடிக்கையான, நியாயமான, துல்லியமான.</string>
    <string name="onboarding_privacy_title">தனியுரிமை முதலில் 🛡️</string>
