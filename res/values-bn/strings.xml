    <string name="personality_splurger_desc">সপ্তাহের দিন: তপস্বী। উইকেন্ড: পার্টি। তোমার ব্যালান্স রোলারকোস্টার!</string>
    <string name="personality_minimalist">মিনিমালিস্ট</string>
    <string name="personality_minimalist_desc">তুমি এতই কম খরচ করো যে তোমার ওয়ালেট নিজের কাজ ভুলে গেছে।</string>
