    <string name="personality_saver">সঞ্চয়কারী</string>
    <string name="personality_saver_desc">ড্রাগন যেমন সোনা রক্ষা করে, তুমি তেমন টাকা রক্ষা করো। অসাধারণ শৃঙ্খলা!</string>
    <string name="personality_balanced">ভারসাম্যপূর্ণ</string>
    <string name="personality_balanced_desc">বুদ্ধিমত্তার সাথে খরচ করো, নিয়মিত সঞ্চয় করো। ফাইন্যান্স ইউনিকর্ন!</string>
    <string name="personality_impulsive">ইম্পালস কিং</string>
    <string name="personality_impulsive_desc">দেখো, পছন্দ হয়, কিনে নাও। তোমার ওয়ালেটের commitment issues!</string>
    <string name="personality_foodie">ফুডি</string>
    <string name="personality_foodie_desc">তোমার পেট তোমার ফাইন্যান্সিয়াল অ্যাডভাইজার। ফুড ডেলিভারি অ্যাপ তোমাকে thank you card পাঠায়।</string>
    <string name="personality_shopper">শপাহোলিক</string>
    <string name="personality_shopper_desc">অনলাইন শপিং ডেলিভারি ছেলে তোমার নাম জানে। Sale সিজন তোমার উৎসব!</string>
