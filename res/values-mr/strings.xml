    <string name="personality_foodie">फूडी</string>
    <string name="personality_foodie_desc">तुमचं पोट तुमचा फायनान्शियल अॅडव्हायझर. फूड डिलिव्हरी अॅप्स तुम्हाला thank you card पाठवतात.</string>
