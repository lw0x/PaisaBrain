    <string name="personality_saver_desc">ಡ್ರ್ಯಾಗನ್ ಚಿನ್ನವನ್ನು ಕಾಪಾಡುವಂತೆ ನೀವು ಹಣವನ್ನು ಕಾಪಾಡುತ್ತೀರಿ. ಅದ್ಭುತ ಶಿಸ್ತು!</string>
    <string name="personality_balanced">ಸಮತೋಲಿತ</string>
    <string name="personality_balanced_desc">ಬುದ್ಧಿವಂತಿಕೆಯಿಂದ ಖರ್ಚು ಮಾಡಿ, ಸ್ಥಿರವಾಗಿ ಉಳಿತಾಯ ಮಾಡುತ್ತೀರಿ. ಹಣಕಾಸು ಯೂನಿಕಾರ್ನ್!</string>
    <string name="personality_impulsive">ಇಂಪಲ್ಸ್ ಕಿಂಗ್</string>
    <string name="personality_impulsive_desc">ನೋಡುತ್ತೀರಿ, ಇಷ್ಟಪಡುತ್ತೀರಿ, ಕೊಳ್ಳುತ್ತೀರಿ. ನಿಮ್ಮ ವ್ಯಾಲೆಟ್‌ಗೆ commitment issues!</string>
    <string name="personality_foodie">ಫುಡ್ಡಿ</string>
    <string name="personality_foodie_desc">ನಿಮ್ಮ ಹೊಟ್ಟೆಯೇ ನಿಮ್ಮ ಹಣಕಾಸು ಸಲಹೆಗಾರ. ಫುಡ್ ಡೆಲಿವರಿ ಆ್ಯಪ್‌ಗಳು ನಿಮಗೆ ಧನ್ಯವಾದ ಕಾರ್ಡ್ ಕಳಿಸುತ್ತವೆ.</string>
    <string name="personality_shopper">ಶಾಪಹಾಲಿಕ್</string>
    <string name="personality_shopper_desc">ಆನ್‌ಲೈನ್ ಶಾಪಿಂಗ್ ಡೆಲಿವರಿ ಹುಡುಗನಿಗೆ ನಿಮ್ಮ ಹೆಸರು ಗೊತ್ತು. ಸೇಲ್ ಸೀಸನ್ ನಿಮ್ಮ ಹಬ್ಬ!</string>
    <string name="personality_splurger">ವೀಕೆಂಡ್ ಸ್ಪ್ಲರ್ಜರ್</string>
    <string name="personality_splurger_desc">ವಾರದ ದಿನ: ಸನ್ಯಾಸಿ. ವೀಕೆಂಡ್: ಪಾರ್ಟಿ. ನಿಮ್ಮ ಬ್ಯಾಲೆನ್ಸ್ ರೋಲರ್‌ಕೋಸ್ಟರ್!</string>
    <string name="personality_minimalist">ಮಿನಿಮಲಿಸ್ಟ್</string>
    <string name="personality_minimalist_desc">ನೀವು ಎಷ್ಟು ಕಡಿಮೆ ಖರ್ಚು ಮಾಡುತ್ತೀರೆಂದರೆ, ನಿಮ್ಮ ವ್ಯಾಲೆಟ್ ತನ್ನ ಕೆಲಸ ಮರೆತಿದೆ.</string>
    <string name="personality_investor">ಹೂಡಿಕೆದಾರ</string>
